# =============================================================================
# enterprise-claw-4j 环境变量模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# ---- Anthropic API (必需) ----
ANTHROPIC_API_KEY=sk-ant-xxx
MODEL_ID=claude-sonnet-4-20250514
MAX_TOKENS=8096
ANTHROPIC_BASE_URL=

# ---- 服务器配置 ----
SERVER_PORT=8080
WORKSPACE_PATH=./workspace
CONTEXT_BUDGET=180000

# ---- 网关配置 ----
DEFAULT_AGENT=luna
MAX_CONCURRENT_AGENTS=10

# ---- 心跳配置 ----
HEARTBEAT_INTERVAL=1800
HEARTBEAT_START_HOUR=9
HEARTBEAT_END_HOUR=22

# ---- Telegram 渠道 (可选) ----
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ---- 飞书渠道 (可选) ----
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ---- 投递队列配置 ----
DELIVERY_POLL_INTERVAL=1000
DELIVERY_MAX_RETRIES=5
DELIVERY_BACKOFF_BASE=5
DELIVERY_BACKOFF_MULTIPLIER=5.0
DELIVERY_JITTER=0.2

# ---- 并发控制 ----
LANE_MAIN_CONCURRENCY=3
LANE_CRON_CONCURRENCY=1
LANE_HEARTBEAT_CONCURRENCY=1
